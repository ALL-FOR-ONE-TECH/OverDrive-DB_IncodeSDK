<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven Settings for OverDrive-DB SDK Deployment

  Usage in CI:
    mvn deploy -s settings.xml -DskipTests -Dgpg.skip=true

  Required environment variables:
    GITHUB_TOKEN  — GitHub PAT with write:packages scope (set automatically in GitHub Actions)
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

    <servers>
        <!-- GitHub Packages — uses GITHUB_TOKEN from environment -->
        <server>
            <id>github</id>
            <username>ALL-FOR-ONE-TECH</username>
            <password>${env.GITHUB_TOKEN}</password>
        </server>
    </servers>

</settings>
